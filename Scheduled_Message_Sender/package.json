  "main": "index.mjs",
  "scripts": {
    "package": "zip -r deployment.zip index.mjs package.json node_modules/ -x '*.DS_Store' -x 'node_modules/.package-lock.json'"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-lambda": "^3.700.0",
    "@aws-sdk/client-scheduler": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0"
  }
}
