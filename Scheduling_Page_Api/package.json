{
  "name": "scheduling-page-api",
  "version": "1.0.0",
  "description": "Scheduling_Page_Api — deterministic propose/mutate gateway for the branded /schedule/ page (M1). CORS Function URL the page calls directly: resolveBinding (the §B10 binding is the auth) -> load booking -> invoke the SHIPPED BCH scheduling_propose / scheduling_mutate seam. The conversational agent path is separate.",
  "main": "index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-lambda": "^3.600.0",
    "@smithy/node-http-handler": "^4.0.0"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "package": "npm run build && zip -j deployment.zip dist/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage --coverageReporters=text --coverageReporters=lcov"
  },
  "author": "",
  "license": "MIT",
  "jest": {
    "collectCoverageFrom": [
      "index.js"
    ],
    "moduleNameMapper": {
      "^@aws-sdk/client-dynamodb$": "<rootDir>/node_modules/@aws-sdk/client-dynamodb",
      "^@aws-sdk/client-lambda$": "<rootDir>/node_modules/@aws-sdk/client-lambda"
    },
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 90,
        "lines": 85,
        "statements": 85
      }
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-jest": "^4.1.0",
    "esbuild": "^0.27.7",
    "jest": "^30.2.0"
  }
}
